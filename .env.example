# AgriFriend Environment Variables

# Data.gov.in API Key for AGMARKNET
# Get your API key from: https://data.gov.in/
VITE_DATA_GOV_API_KEY=your_api_key_here

# API Mode: 'real' for live data, 'mock' for demo data, 'hybrid' for fallback
VITE_API_MODE=hybrid

# AGMARKNET API Base URL
VITE_AGMARKNET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# Enable API caching (recommended for production)
VITE_ENABLE_API_CACHE=true

# Cache duration in minutes
VITE_CACHE_DURATION=30

# Enable debug logging
VITE_DEBUG_API=false
